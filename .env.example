# ============================================================================
# Podcast Knowledge Agent — minimal config
# ============================================================================
# The default path (agent-driven usage) only needs ONE key: PKA_GROQ_API_KEY.
# The calling agent (Claude Code / OpenClaw / Codex / Claude Desktop) supplies
# its own LLM to summarize the transcript — no separate model config needed.
# ============================================================================

# --- Required: Groq Whisper API (fast cloud ASR) ---
# Free tier: ~8 hours of audio/day, no credit card required.
# Get a key at: https://console.groq.com
PKA_GROQ_API_KEY=gsk_your-groq-key-here

# --- Optional: built-in LLM pipeline ------------------------------------------
# Set these ONLY if you want the standalone ``extract_knowledge`` tool (the
# full pipeline with summary + agent memory blocks). Agents should leave
# these empty and handle summarization themselves.
# Accepts any OpenAI-compatible endpoint (OpenRouter, OpenAI, DeepSeek,
# Moonshot, local vLLM, etc).
# PKA_LLM_API_KEY=sk-...
# PKA_LLM_BASE_URL=https://openrouter.ai/api/v1
# PKA_LLM_MODEL=meta-llama/llama-4-maverick

# --- Groq model (optional override) -------------------------------------------
# PKA_GROQ_MODEL=whisper-large-v3-turbo

# --- Storage ------------------------------------------------------------------
PKA_DATA_DIR=./data

# --- Optional: REST API mode --------------------------------------------------
# Only needed when running the FastAPI + Celery deployment. MCP usage does
# not need any of these.
# PKA_HOST=0.0.0.0
# PKA_PORT=8000
# PKA_DEBUG=false
# PKA_REDIS_URL=redis://localhost:6379/0
# PKA_DATABASE_URL=sqlite+aiosqlite:///./data/jobs.db
