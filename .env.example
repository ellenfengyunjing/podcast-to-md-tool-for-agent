# Server
PKA_HOST=0.0.0.0
PKA_PORT=8000
PKA_DEBUG=true

# OpenRouter API (single key for all AI services)
PKA_OPENROUTER_API_KEY=sk-or-v1-your-key-here
PKA_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ASR Model (kept for reference, not used when backend=local)
PKA_ASR_MODEL=openai/gpt-4o-audio-preview
# Backend: "api" (OpenRouter) or "local" (faster-whisper CPU)
PKA_ASR_BACKEND=local

# LLM Model (chat completions for summarization & memory extraction)
PKA_LLM_MODEL=meta-llama/llama-4-maverick

# Embedding Model (for future RAG integration)
PKA_EMBEDDING_MODEL=baai/bge-large-en-v1.5

# Local ASR fallback (only used when PKA_ASR_BACKEND=local)
PKA_WHISPER_MODEL_SIZE=large-v3

# Celery / Redis
PKA_REDIS_URL=redis://localhost:6379/0

# Storage
PKA_DATA_DIR=./data
PKA_DATABASE_URL=sqlite+aiosqlite:///./data/jobs.db
