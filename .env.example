# Server
PKA_HOST=0.0.0.0
PKA_PORT=8000
PKA_DEBUG=true

# OpenRouter API (for LLM summarization)
PKA_OPENROUTER_API_KEY=sk-or-v1-your-key-here
PKA_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ASR Backend: "local" (faster-whisper CPU), "groq" (Groq Whisper API), "api" (OpenRouter)
# Recommended: "groq" for speed, "local" for offline/free usage
PKA_ASR_BACKEND=local

# Groq API (for cloud ASR - extremely fast, free tier: 8h audio/day)
# Get key at: https://console.groq.com
PKA_GROQ_API_KEY=gsk_your-groq-key-here

# ASR Model (only used when PKA_ASR_BACKEND=api)
PKA_ASR_MODEL=openai/gpt-4o-audio-preview

# LLM Model (chat completions for summarization & memory extraction)
PKA_LLM_MODEL=meta-llama/llama-4-maverick

# Embedding Model (for future RAG integration)
PKA_EMBEDDING_MODEL=baai/bge-large-en-v1.5

# Local ASR (only used when PKA_ASR_BACKEND=local)
PKA_WHISPER_MODEL_SIZE=large-v3

# Celery / Redis
PKA_REDIS_URL=redis://localhost:6379/0

# Storage
PKA_DATA_DIR=./data
PKA_DATABASE_URL=sqlite+aiosqlite:///./data/jobs.db
